<mvc:View
    controllerName="com.abics.casestudy.controller.Products"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
    displayBlock="true">

    <f:FlexibleColumnLayout id="fcl" layout="OneColumn">

        <f:beginColumnPages>
            <mvc:XMLView viewName="com.abics.casestudy.view.ProductsMaster" id="masterView"/>
        </f:beginColumnPages>

        <f:midColumnPages>
            <mvc:XMLView viewName="com.abics.casestudy.view.ProductsDetail" id="detailView"/>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>

</mvc:View>