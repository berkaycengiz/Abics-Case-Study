<mvc:View
    controllerName="com.abics.casestudy.controller.App"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"> 
    
    <tnt:ToolPage id="toolPage" sideExpanded="true">
        
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu2" type="Transparent" press=".onSideNavButtonPress" />
                <Title text="{i18n>appHeaderTitle}" />
            </tnt:ToolHeader>
        </tnt:header>
        
        <tnt:sideContent>
            <tnt:SideNavigation selectedKey="{app>/selectedKey}">
                <tnt:item>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="{i18n>navHome}" icon="sap-icon://home" key="home" select=".onNavItemSelect" />
                        <tnt:NavigationListItem text="{i18n>navProducts}" icon="sap-icon://product" key="products" select=".onNavItemSelect" />
                        <tnt:NavigationListItem text="{i18n>navSuppliers}" icon="sap-icon://supplier" key="suppliers" select=".onNavItemSelect" />
                    </tnt:NavigationList>
                </tnt:item>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <NavContainer id="app" />
        </tnt:mainContents>
        
    </tnt:ToolPage>

</mvc:View>