    xmlns="sap.m"
    xmlns:f="sap.f"
    displayBlock="true">

    <f:FlexibleColumnLayout id="supplierFCL" layout="OneColumn">

        <f:beginColumnPages>
            <mvc:XMLView viewName="com.abics.casestudy.view.SuppliersMaster" id="supplierMasterView"/>
        </f:beginColumnPages>

        <f:midColumnPages>
            <mvc:XMLView viewName="com.abics.casestudy.view.SuppliersDetail" id="supplierDetailView"/>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>

</mvc:View>
