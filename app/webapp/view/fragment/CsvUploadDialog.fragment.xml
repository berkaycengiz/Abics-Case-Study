<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified">
    
    <Dialog id="csvDialog" title="{i18n>csvUpload}" contentWidth="36rem" resizable="true" draggable="true">
        <content>
            <VBox class="sapUiContentPadding" width="100%">

                <MessageStrip
                    text="{i18n>csvInstructions}"
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom"/>

                <Label text="{i18n>selectFile}" class="sapUiSmallMarginBottom"/>
                <u:FileUploader
                    id="csvFileUploader"
                    fileType="csv"
                    mimeType="text/csv,application/vnd.ms-excel"
                    placeholder="{i18n>chooseCsv}"
                    change=".onCsvFileChange"
                    class="sapUiSmallMarginBottom"/>

                <VBox id="csvValidationResults" visible="false" class="sapUiSmallMarginTop" width="100%">
                    <Text
                        text="{= ${csvResult>/fileName} + ' (' + ${csvResult>/totalRows} + ' rows)'}"
                        class="sapUiSmallMarginBottom sapUiSmallText"/>

                    <List
                        showSeparators="None"
                        items="{csvResult>/checks}">
                        <CustomListItem type="Inactive">
                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                <core:Icon
                                    src="{= ${csvResult>passed} ? 'sap-icon://accept' : 'sap-icon://decline'}"
                                    color="{= ${csvResult>passed} ? 'Positive' : 'Negative'}"
                                    size="1rem"
                                    class="sapUiSmallMarginEnd"/>
                                <VBox>
                                    <Text text="{csvResult>label}"/>
                                    <Text text="{csvResult>detail}" class="sapUiSmallText sapUiTextColorQuaternary"/>
                                </VBox>
                                <core:HTML content="&lt;span style='margin-left:auto'&gt;&lt;/span&gt;"/>
                                <ObjectStatus
                                    text="{= ${csvResult>passed} ? 'OK' : 'Error'}"
                                    state="{= ${csvResult>passed} ? 'Success' : 'Error'}"/>
                            </HBox>
                        </CustomListItem>
                    </List>
                    <Panel
                        id="csvErrorPanel"
                        visible="false"
                        headerText="{i18n>validationResults}"
                        expandable="true"
                        expanded="true"
                        class="sapUiSmallMarginTop">
                        <List items="{csvResult>/errors}" showSeparators="Inner">
                            <StandardListItem
                                title="{csvResult>message}"
                                description="{i18n>row}: {csvResult>row} | {i18n>column}: {csvResult>column}"
                                type="Inactive"
                                icon="sap-icon://error"
                                iconInset="false"/>
                        </List>
                    </Panel>

                </VBox>

            </VBox>
        </content>

        <beginButton>
            <Button
                id="uploadCsvBtn"
                text="{i18n>upload}"
                type="Emphasized"
                icon="sap-icon://upload"
                enabled="false"
                press=".onUploadCsv"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>close}" press=".onCsvDialogClose"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>