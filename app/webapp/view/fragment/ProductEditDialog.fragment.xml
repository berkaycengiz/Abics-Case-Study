<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog
        id="productEditDialog"
        title="{i18n>editProduct}">
        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12">
                
                <Label text="{i18n>colName}" required="true"/>
                <Input id="productEditName" value="{editModel>/name}" valueStateText="{i18n>fieldRequired}"/>

                <Label text="{i18n>colDescription}"/>
                <Input id="productEditDescription" value="{editModel>/description}"/>

                <Label text="{i18n>colPrice}"/>
                <Input 
                    id="productEditPrice"
                    value="{
                        path: 'editModel>/price',
                        type: 'sap.ui.model.odata.type.Decimal',
                        constraints: { precision: 15, scale: 2 }
                    }"
                    valueStateText="{i18n>priceMustBePositive}"/>

                <Label text="{i18n>colCurrency}" required="true"/>
                <ComboBox
                    id="productEditCurrency"
                    selectedKey="{editModel>/currency_code}"
                    items="{
                        path: 'products>/currencies',
                        templateShareable: false
                    }">
                    <core:Item key="{products>code}" text="{products>code} - {products>name}"/>
                </ComboBox>

                <Label text="{i18n>colStock}"/>
                <Input id="productEditStocks" value="{editModel>/stocks}" type="Number" valueStateText="{i18n>stocksMustBePositive}"/>

                <Label text="{i18n>colSupplier}" required="true"/>
                <ComboBox
                    id="productEditSupplier"
                    selectedKey="{editModel>/supplier_ID}"
                    items="{
                        path: 'products>/suppliers',
                        templateShareable: false
                    }">
                    <core:Item key="{products>ID}" text="{products>name}"/>
                </ComboBox>

            </f:SimpleForm>
        </content>
        <buttons>
            <Button text="{i18n>save}" type="Emphasized" icon="sap-icon://save" press=".onSaveEditDialog" />
            <Button text="{i18n>cancel}" press=".onCancelEditDialog" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
