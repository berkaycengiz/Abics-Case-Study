<mvc:View controllerName="com.abics.casestudy.controller.Home"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" xmlns:layout="sap.ui.layout">
    
    <Page title="{i18n>homeTitle}" showHeader="false">
        <content>
            <layout:Grid defaultSpan="L6 M12 S12" class="sapUiSmallMargin">
                
                <Panel headerText="{i18n>latestProducts}" expanded="true" class="sapUiTinyMarginBottom">
                    <List id="latestProductsList" items="{path: '/Products', length: 3, parameters: { $orderby: 'createdAt desc', $expand: 'supplier' }}" noDataText="{i18n>noProductsFound}">
                        <ObjectListItem 
                            title="{name}" 
                            number="{
                                    parts: [
                                        {path: 'price'}, 
                                        {path: 'currency_code'}
                                    ],
                                    type: 'sap.ui.model.type.Currency',
                                    formatOptions: {
                                        showMeasure: false 
                                    }
                                }"
                            numberUnit="{currency_code}"
                            type="Navigation" 
                            press=".onNavigateToProducts">
                            <attributes>
                                <ObjectAttribute text="{i18n>homeDescription}: {description}" />
                                <ObjectAttribute text="{i18n>homeAddedAt}: {
                                    path: 'createdAt',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: {
                                        source: {
                                            pattern: 'yyyy-MM-ddTHH:mm:ss.SSSX'
                                        },
                                        style: 'medium',
                                        relative: true
                                    }
                                }" />
                                <ObjectAttribute text="{i18n>colSupplier}: {supplier/name}"></ObjectAttribute>
                            </attributes>
                        </ObjectListItem>
                    </List>
                    <Button text="{i18n>viewAllProducts}" press=".onNavigateToProducts" width="100%" type="Transparent"/>
                </Panel>

                <Panel headerText="{i18n>latestSuppliers}" expanded="true">
                    <List id="latestSuppliersList" items="{path: '/Suppliers', length: 3, parameters: { $orderby: 'createdAt desc', $expand: 'country' }}" noDataText="{i18n>noSuppliersFound}">
                        <ObjectListItem 
                            title="{name}" 
                            intro="{city}, {country_code}"
                            type="Navigation" 
                            press=".onNavigateToSuppliers">
                            <attributes>
                                <ObjectAttribute text="{i18n>supplierPhone}: {phone}" /> 
                                <ObjectAttribute text="{i18n>supplierEmail}: {email}" /> 
                            </attributes>
                        </ObjectListItem>
                    </List>
                    <Button text="{i18n>viewAllSuppliers}" press=".onNavigateToSuppliers" width="100%" type="Transparent"/>
                </Panel>

            </layout:Grid>
        </content>
    </Page>
</mvc:View>