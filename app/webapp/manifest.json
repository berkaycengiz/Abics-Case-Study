{
	"_version": "1.12.0",

	"sap.app": {
		"id": "com.abics.casestudy",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "${version}"
		},
		"sourceTemplate": {
			"id": "generator-ui5-app",
			"version": "1.1.0"
		},	
		"dataSources": {
            "mainService": {
                "uri": "/odata/v4/product/",
                "type": "OData",
                "settings": {
                    "odataVersion": "4.0"
                }
            }
        }
	},

	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},

	"sap.ui5": {
		"rootView": {
			"viewName": "com.abics.casestudy.view.App",
			"type": "XML",
			"id": "app"
		},

		"dependencies": {
			"minUI5Version": "1.146.0",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {},
				"sap.tnt": {},
				"sap.f": {},
    			"sap.ui.layout": {}
			}
		},

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.abics.casestudy.i18n.i18n",
					"supportedLocales": ["en", "de", "tr"],
					"fallbackLocale": "en",
					"async": true
				}
			},
			"": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "operationMode": "Server",
                    "groupId": "$auto",
                    "synchronizationMode": "None"
                }
            }
		},

		"resources": {
			"css": [
				{
					"uri": "style.css"
				}
			]
		},

		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"viewType": "XML",
				"viewPath": "com.abics.casestudy.view",
				"controlId": "app",
				"controlAggregation": "pages",
				"async": true
			},
			"routes": [
				{
					"name": "home",
					"pattern": "",
					"target": "TargetHome"
				},
				{
					"name": "products",
					"pattern": "products",
					"target": "TargetProducts"
				},
				{
					"name": "productsDetail",
					"pattern": "products/{productPath}",
					"target": "TargetProducts" 
				},
				{
					"name": "suppliers",
					"pattern": "suppliers",
					"target": "TargetSuppliers"
				}
			],
			"targets": {
				"TargetHome": {
					"viewName": "Home",
					"viewLevel": 1
				},
				"TargetProducts": {
					"viewName": "Products",
					"viewLevel": 2
				},
				"TargetSuppliers": {
					"viewName": "Suppliers",
					"viewLevel": 2
				}
			}
		}
	}
}
